# Database (Supabase / Neon / Postgres)
# Drizzle migrate and @vela/db expect this exact name. If Vercel + Neon only created
# POSTGRES_URL (or similar), copy the pooled/serverless URL here as DATABASE_URL, or
# add DATABASE_URL in Vercel for the "Development" environment and run `vercel env pull`.
DATABASE_URL=

# Blob Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# AI (Vercel AI Gateway) — models as "provider/model" route through the gateway
AI_GATEWAY_API_KEY=

#
# Console-only deploy lock — HTTP Basic Auth for /console and /api/console/* only
# (landing and other routes stay public). Omit in dev.
# Browser: user = VELA_SITE_USER (default vela), password = VELA_SITE_PASSWORD.
#
VELA_SITE_PASSWORD=
VELA_SITE_USER=

# Agent loop — max model↔tool rounds for non-workflow turns (default 20)
VELA_AGENT_MAX_TOOL_STEPS=

# Memory — max chat messages loaded for short-term context (optional, default 50)
VELA_SHORT_TERM_MESSAGE_LIMIT=

# Long-term memory (optional) — requires AI Gateway or provider embedding model
VELA_LONG_TERM_MEMORY=
VELA_EMBEDDING_MODEL=
VELA_LONG_TERM_MAX_CHUNKS=
VELA_LONG_TERM_TOP_K=

# Skill resolver (optional) — semantic routing over skills_registry
# Set VELA_SKILL_SEMANTIC=0 to disable semantic ranking and use keywords only.
VELA_SKILL_SEMANTIC=
VELA_SKILL_EMBEDDING_MODEL=
VELA_SKILL_TOP_K=
VELA_SKILL_MIN_SCORE=

# ─── Chat SDK (https://chat-sdk.dev/) — multi-channel webhooks + thread state
# Production: set REDIS_URL (e.g. Upstash) so subscriptions and locks survive cold starts.
# Local/dev: omit REDIS_URL to use in-memory state (single process only).
REDIS_URL=
VELA_BOT_USER_NAME=vela

# Slack — Events API (adapter reads SLACK_BOT_TOKEN + SLACK_SIGNING_SECRET)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord — interactions / gateway (adapter reads DISCORD_BOT_TOKEN + DISCORD_PUBLIC_KEY + DISCORD_APPLICATION_ID)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# Microsoft Teams — Bot Framework (adapter reads TEAMS_APP_ID, TEAMS_APP_PASSWORD, TEAMS_APP_TENANT_ID as needed)
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TENANT_ID=

# MCP — background discovery during ingest (ms between full syncs, default 300000)
VELA_MCP_AUTOSYNC_MS=

# MCP — re-run tools/list before tools/call when health failed, missing, or older than this TTL (ms, default 120000)
VELA_MCP_HEALTH_REFRESH_MS=

# Vercel Cron — protect /api/cron/mcp-sync (Authorization: Bearer <this>)
CRON_SECRET=
